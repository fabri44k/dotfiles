// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "relative_line_numbers": "enabled",
  // Synced from nvim options.lua
  "tab_size": 4,
  "hard_tabs": false,
  "vertical_scroll_margin": 10,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,
  "current_line_highlight": "all",
  "cursor_blink": true,
  "ensure_final_newline_on_save": true,
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
    },
    "C": {
      "show_edit_predictions": true,
    },
  },
  "show_edit_predictions": true,
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "model_parameters": [],
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "disable_ai": true,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": false,
    },
    "mode": "eager",
    "provider": "copilot",
  },
  "buffer_font_weight": 400.0,
  "buffer_font_family": "Ioskeley Mono",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_menu": true,
    "show_user_picture": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "lsp": {
    "cspell": {
      "settings": {
        "cSpell": {
          "language": "en,it",
          "import": ["@cspell/dict-it-it/cspell-ext.json"],
          "dictionaries": ["en_US", "it-it"],
        },
      },
    },
  },
}
